<Window x:Class="SecKey.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SecKey.App.ViewModels"
        xmlns:v="clr-namespace:SecKey.App.Views"
        mc:Ignorable="d"
        Title="SecKey - Intune Configuration Manager" Height="760" Width="1280" MinHeight="560" MinWidth="980"
        Icon="Assets/JosephThePlatypus.ico"
        Background="#0B1220"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#111A2C"/>
        <SolidColorBrush x:Key="SidebarButtonBrush" Color="#1B2740"/>
        <SolidColorBrush x:Key="SidebarButtonHoverBrush" Color="#2A3B5F"/>
        <SolidColorBrush x:Key="SidebarButtonPressedBrush" Color="#345084"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SidebarButtonBrush}"/>
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Margin="2,0,2,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       Foreground="#F3F7FF"
                                       FontSize="{TemplateBinding FontSize}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="#F3F7FF"/>
                                <Setter TargetName="border" Property="Background" Value="#243550"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="Background" Value="#101A2E"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="Background" Value="#101A2E"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True" Focusable="False">
                                    <Border Background="#111827" BorderBrush="#334155" BorderThickness="1" Padding="2">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}"><v:LoginView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><v:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:IntuneAppsViewModel}"><v:IntuneAppsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PoliciesViewModel}"><v:PoliciesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:InfrastructureViewModel}"><v:InfrastructureView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GroupsViewModel}"><v:GroupsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConditionalAccessViewModel}"><v:ConditionalAccessView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UploadAppViewModel}"><v:UploadAppView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeviceTaggingViewModel}"><v:DeviceTaggingView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SecurityAnalyzerViewModel}"><v:SecurityAnalyzerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemHardeningViewModel}"><v:SystemHardeningView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RebootAnalyzerViewModel}"><v:RebootAnalyzerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:FileIntegrityViewModel}"><v:FileIntegrityView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:IntuneBackupViewModel}"><v:IntuneBackupView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CertificateManagerViewModel}"><v:CertificateManagerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SecureWipeViewModel}"><v:SecureWipeView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkTrafficViewModel}"><v:NetworkTrafficView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HashScannerViewModel}"><v:HashScannerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CredentialManagerViewModel}"><v:CredentialManagerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:EncryptedClipboardViewModel}"><v:EncryptedClipboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SshKeyManagerViewModel}"><v:SshKeyManagerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:FileEncryptionToolViewModel}"><v:FileEncryptionToolView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SecurityVaultViewModel}"><v:SecurityVaultView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:YaraScannerViewModel}"><v:YaraScannerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CveSearchViewModel}"><v:CveSearchView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ForensicsAnalyzerViewModel}"><v:ForensicsAnalyzerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdvancedForensicsViewModel}"><v:AdvancedForensicsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GlobalSecureAccessViewModel}"><v:GlobalSecureAccessView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WdacAppLockerViewModel}"><v:WdacAppLockerView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemAuditViewModel}"><v:SystemAuditView/></DataTemplate>
    </Window.Resources>

    <Grid Background="#0B1220">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#101A2E" Foreground="#F3F7FF" FontSize="13">
            <MenuItem Header="_File">
                <MenuItem Header="_Export Settings" Command="{Binding ExportSettingsCommand}"/>
                <MenuItem Header="_Import Settings" Command="{Binding ImportSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
                <MenuItem Header="_View">
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" InputGestureText="F5"/>
                    <MenuItem Header="_Dark Mode" IsCheckable="True" IsChecked="{Binding IsDarkMode, Mode=TwoWay}" Command="{Binding ToggleDarkModeCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Check for Updates" Command="{Binding CheckForUpdatesCommand}"/>
                <Separator/>
                <MenuItem Header="_Open Help File" Command="{Binding OpenHelpCommand}"/>
                <MenuItem Header="_Skip Reasons Reference" Command="{Binding OpenSkipReasonsCommand}"/>
                <MenuItem Header="_About SecKey" Command="{Binding OpenAboutCommand}"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Preferences" Command="{Binding OpenPreferencesCommand}"/>
                <MenuItem Header="_View Logs" Command="{Binding OpenLogsCommand}"/>
                <MenuItem Header="_Advanced Options" Command="{Binding OpenAdvancedCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Background="#0B1220">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" Margin="16" CornerRadius="18">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Image Source="Assets/PlatypusToolsLogo.png" Width="88" Height="88" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock Text="SecKey" Foreground="#F8FAFF" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Tenant security deployment" Foreground="#9FB2D5" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="0,16,0,16" Background="#0E1628" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Current Auth" Foreground="#8EA2C8" FontSize="12"/>
                        <TextBlock Text="{Binding AuthStatus}" Foreground="#E8F0FF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Content="Sign In / Out" Command="{Binding ShowLoginCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Dashboard" Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Deploy/Remove Secure Keyboard infra" Command="{Binding ShowInfrastructureCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Intune Apps" Command="{Binding ShowAppsCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Upload App" Command="{Binding ShowUploadCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Compliance + Config" Command="{Binding ShowPoliciesCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Groups" Command="{Binding ShowGroupsCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Conditional Access" Command="{Binding ShowCaCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Device Tagging" Command="{Binding ShowDeviceTaggingCommand}" Style="{StaticResource NavButtonStyle}"/>

                        <Separator Background="#2A3B5F" Margin="0,12,0,12" Height="1"/>

                        <TextBlock Text="Deployment Extensions" Foreground="#9FB2D5" FontSize="11" Margin="12,8,0,8" FontWeight="SemiBold"/>
                        <Button Content="Global Secure Access" Command="{Binding ShowGlobalSecureAccessCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="WDAC / AppLocker" Command="{Binding ShowWdacAppLockerCommand}" Style="{StaticResource NavButtonStyle}"/>

                        <Separator Background="#2A3B5F" Margin="0,12,0,12" Height="1"/>

                        <TextBlock Text="Security &amp; Analysis" Foreground="#9FB2D5" FontSize="11" Margin="12,8,0,8" FontWeight="SemiBold"/>
                        <Button Content="AD Security Analysis" Command="{Binding ShowSecurityAnalyzerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="System Hardening" Command="{Binding ShowSystemHardeningCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Reboot &amp; Crash Analysis" Command="{Binding ShowRebootAnalyzerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="File Integrity Monitor" Command="{Binding ShowFileIntegrityCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Intune Backup" Command="{Binding ShowIntuneBackupCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Certificate Manager" Command="{Binding ShowCertificateManagerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Credential Manager" Command="{Binding ShowCredentialManagerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="SSH Key Manager" Command="{Binding ShowSshKeyManagerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Encrypted Clipboard" Command="{Binding ShowEncryptedClipboardCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="File Encryption" Command="{Binding ShowFileEncryptionCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Security Vault" Command="{Binding ShowSecurityVaultCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Network Traffic" Command="{Binding ShowNetworkTrafficCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Hash Scanner" Command="{Binding ShowHashScannerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="YARA Scanner" Command="{Binding ShowYaraScannerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="CVE Search" Command="{Binding ShowCveSearchCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Forensics Analyzer" Command="{Binding ShowForensicsAnalyzerCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Advanced Forensics" Command="{Binding ShowAdvancedForensicsCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="System Audit" Command="{Binding ShowSystemAuditCommand}" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Secure Wipe" Command="{Binding ShowSecureWipeCommand}" Style="{StaticResource NavButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="3" Text="Tip: start with Sign In / Out and Validate Access before full deployment." Foreground="#8DA2C9" TextWrapping="Wrap" Margin="2,8,2,2"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="0,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#101A2E" CornerRadius="14" Padding="18" Margin="0,0,0,12">
                <TextBlock Text="Configuration Workspace" FontSize="18" FontWeight="SemiBold" Foreground="#ECF3FF"/>
            </Border>

            <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="16" Padding="0">
                <ContentControl Content="{Binding CurrentView}" Margin="0"/>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>
