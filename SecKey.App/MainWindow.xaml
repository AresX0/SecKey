<Window x:Class="SecKey.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SecKey.App"
        xmlns:vm="clr-namespace:SecKey.App.ViewModels"
        xmlns:v="clr-namespace:SecKey.App.Views"
        mc:Ignorable="d"
        Title="SecKey - Intune Configuration Manager" Height="720" Width="1200" MinHeight="500" MinWidth="800">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}"><v:LoginView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><v:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:IntuneAppsViewModel}"><v:IntuneAppsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PoliciesViewModel}"><v:PoliciesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GroupsViewModel}"><v:GroupsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConditionalAccessViewModel}"><v:ConditionalAccessView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UploadAppViewModel}"><v:UploadAppView/></DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2937">
            <StackPanel Margin="12">
                <TextBlock Text="SecKey" Foreground="White" FontSize="24" FontWeight="Bold" Margin="4,8,4,16"/>
                <TextBlock Text="{Binding AuthStatus}" Foreground="#9CA3AF" Margin="4,0,4,16" TextWrapping="Wrap"/>
                <Button Content="Sign in / out"   Command="{Binding ShowLoginCommand}"      Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
                <Button Content="Dashboard"        Command="{Binding ShowDashboardCommand}"  Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
                <Button Content="Intune Apps"      Command="{Binding ShowAppsCommand}"       Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
                <Button Content="Upload App"       Command="{Binding ShowUploadCommand}"     Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
                <Button Content="Compliance / Config" Command="{Binding ShowPoliciesCommand}" Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
                <Button Content="Groups"           Command="{Binding ShowGroupsCommand}"     Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
                <Button Content="Conditional Access" Command="{Binding ShowCaCommand}"       Margin="0,4" Padding="8" Background="#374151" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>
</Window>
