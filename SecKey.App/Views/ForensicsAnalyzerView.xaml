<UserControl x:Class="SecKey.App.Views.ForensicsAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Forensics Analyzer" FontSize="22" FontWeight="Bold" Foreground="White" Background="{DynamicResource SectionHeaderBrush}" Padding="14" Margin="0,0,0,8"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Quick Scan" Command="{Binding CaptureSnapshotCommand}"/>
            <Button Grid.Column="2" Content="Deep Analysis" Command="{Binding RunDeepAnalysisCommand}"/>
            <Button Grid.Column="3" Content="Export CSV" Command="{Binding ExportSnapshotCommand}"/>
            <Button Grid.Column="4" Content="Export HTML" Command="{Binding ExportHtmlReportCommand}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,8,0"><TextBlock Text="{Binding CriticalFindings, StringFormat=Critical: {0}}" Foreground="#B91C1C" FontWeight="Bold"/></Border>
            <Border Grid.Column="1" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,8,0"><TextBlock Text="{Binding HighFindings, StringFormat=High: {0}}" Foreground="#C2410C" FontWeight="Bold"/></Border>
            <Border Grid.Column="2" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,8,0"><TextBlock Text="{Binding MediumFindings, StringFormat=Medium: {0}}" FontWeight="Bold"/></Border>
            <Border Grid.Column="3" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8"><TextBlock Text="{Binding AnalysisDuration, StringFormat=Duration: {0:c}}" FontWeight="Bold"/></Border>
        </Grid>

        <TabControl Grid.Row="3">
            <TabItem Header="Findings">
                <DataGrid ItemsSource="{Binding Findings}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="110"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="220"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Processes">
                <DataGrid ItemsSource="{Binding Processes}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="90"/>
                        <DataGridTextColumn Header="Memory MB" Binding="{Binding WorkingSetMb}" Width="100"/>
                        <DataGridTextColumn Header="Responding" Binding="{Binding Responding}" Width="100"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Timeline">
                <DataGrid ItemsSource="{Binding Timeline}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="190"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160"/>
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="110"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Top Processes">
                <DataGrid ItemsSource="{Binding TopProcesses}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="240"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="90"/>
                        <DataGridTextColumn Header="Memory MB" Binding="{Binding MemoryMb}" Width="120"/>
                        <DataGridTextColumn Header="Responding" Binding="{Binding Responding}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Suspicious Files">
                <DataGrid ItemsSource="{Binding SuspiciousFilesList}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="220"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*"/>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Registry">
                <DataGrid ItemsSource="{Binding RegistryEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*"/>
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Security Events">
                <DataGrid ItemsSource="{Binding SecurityEventsList}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="190"/>
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="120"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
    </Grid>
</UserControl>
