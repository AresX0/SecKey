<UserControl x:Class="SecKey.App.Views.FileIntegrityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="File Integrity Monitor" FontSize="22" FontWeight="Bold" Foreground="White" Background="{DynamicResource SectionHeaderBrush}" Padding="16"/>

        <Grid Grid.Row="1" Margin="14,10,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SelectedDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseDirectoryCommand}" Margin="0,0,8,0" Padding="10,6"/>
            <Button Grid.Column="2" Content="Create Baseline" Command="{Binding CreateBaselineCommand}" CommandParameter="{Binding SelectedDirectory}" Margin="0,0,8,0" Padding="10,6"/>
            <Button Grid.Column="3" Content="Load Baseline" Command="{Binding LoadBaselineCommand}" Margin="0,0,8,0" Padding="10,6"/>
            <Button Grid.Column="4" Content="Save Baseline" Command="{Binding SaveBaselineCommand}" Margin="0,0,8,0" Padding="10,6"/>
            <Button Grid.Column="5" Content="Compare" Command="{Binding CompareWithBaselineCommand}" Margin="0,0,8,0" Padding="10,6"/>
            <Button Grid.Column="6" Content="Cancel" Command="{Binding CancelCommand}" Padding="10,6"/>
        </Grid>

        <Grid Grid.Row="2" Margin="14,0,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,6,0">
                <TextBlock Text="{Binding BaselineDisplayName}" TextWrapping="Wrap"/>
            </Border>
            <Border Grid.Column="1" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,6,0">
                <TextBlock Text="{Binding TotalBaselineFiles, StringFormat=Baseline Files: {0}}"/>
            </Border>
            <Border Grid.Column="2" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8">
                <TextBlock Text="{Binding TotalChanges, StringFormat=Total Changes: {0}}"/>
            </Border>
        </Grid>

        <TabControl Grid.Row="3" Margin="14,0,14,8">
            <TabItem Header="Added Files">
                <DataGrid ItemsSource="{Binding AddedFiles}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Modified Files">
                <DataGrid ItemsSource="{Binding ModifiedFiles}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Deleted Files">
                <DataGrid ItemsSource="{Binding DeletedFiles}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="4" Margin="14,0,14,12" Background="{DynamicResource StatusPanelBrush}" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Padding="8">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
