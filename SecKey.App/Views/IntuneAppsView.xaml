<UserControl x:Class="SecKey.App.Views.IntuneAppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10,8" Background="#E8EEF9" BorderBrush="#C8D5EC" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Deployment Status:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding DeploymentStatus}" Margin="10,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#1F2937"/>
            </Grid>
        </Border>

        <Expander DockPanel.Dock="Bottom" Margin="0,12,0,0" Header="Deployment History" IsExpanded="False">
            <DataGrid ItemsSource="{Binding DeploymentHistory}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MinHeight="120" MaxHeight="220">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="90"/>
                    <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="180"/>
                    <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="110"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Intune Apps" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,6" Margin="16,0,0,0"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#6B7280"/>
        </StackPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Content="Deploy Intune Applications" Command="{Binding DeployIntuneAppsCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Store Assignments" Command="{Binding DeployStoreAssignmentsCommand}" Padding="14,6" Margin="0,0,8,8"/>
        </WrapPanel>

        <Expander DockPanel.Dock="Top" Margin="0,0,0,12" Header="Native Deployment Settings" IsExpanded="False">
            <DataGrid ItemsSource="{Binding SettingsInventory}" AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="140" MaxHeight="220">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Setting" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Value" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160" IsReadOnly="True" ElementStyle="{StaticResource SettingSourceBadgeTextStyle}"/>
                    <DataGridTemplateColumn Header="Actions" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save" Command="{Binding DataContext.SaveSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4" Margin="0,0,8,0"/>
                                    <Button Content="Go to editor" Command="{Binding DataContext.NavigateToSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="240"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
