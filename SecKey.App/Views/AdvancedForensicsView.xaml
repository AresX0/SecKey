<UserControl x:Class="SecKey.App.Views.AdvancedForensicsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Advanced Forensics - DFIR Toolkit" FontSize="22" FontWeight="Bold" Foreground="White" Background="{DynamicResource SectionHeaderBrush}" Padding="14" Margin="0,0,0,8"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <Button Content="Build Timeline" Command="{Binding BuildTimelineCommand}" Margin="0,0,8,0"/>
            <Button Content="Export Timeline" Command="{Binding ExportTimelineCommand}" Margin="0,0,8,0"/>
            <Button Content="Capture Processes" Command="{Binding CaptureProcessSnapshotCommand}" Margin="0,0,8,0"/>
            <Button Content="Acquire Memory" Command="{Binding AcquireMemoryCommand}" Margin="0,0,8,0"/>
            <Button Content="Run Volatility" Command="{Binding RunVolatilityPluginsCommand}" Margin="0,0,8,0"/>
            <Button Content="Run KAPE" Command="{Binding RunKapeCommand}" Margin="0,0,8,0"/>
            <Button Content="Refresh Processes" Command="{Binding RefreshProcessesCommand}"/>
        </WrapPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="Memory">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Global Memory Capture Settings" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Output Folder:" VerticalAlignment="Center" Width="120"/>
                                <TextBox Text="{Binding DumpOutputPath, UpdateSourceTrigger=PropertyChanged}" Width="430" Margin="0,0,8,0"/>
                                <Button Content="Browse" Command="{Binding BrowseDumpOutputCommand}" Margin="0,0,8,0" Padding="10,6"/>
                                <TextBlock Text="Format:" VerticalAlignment="Center" Width="55"/>
                                <ComboBox ItemsSource="{Binding DumpFormats}" SelectedItem="{Binding DumpFormat}" Width="120"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Grid.Row="0" Header="WinPmem - Full Memory Acquisition" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="WinPmem Path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding WinPmemPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseWinPmemCommand}" Margin="0,0,8,0" Padding="10,6"/>
                                    <Button Grid.Column="3" Content="Download" Command="{Binding DownloadWinPmemCommand}" Background="#4CAF50" Foreground="White" Margin="0,0,8,0" Padding="10,6"/>
                                </Grid>
                                <StackPanel Margin="8,0,8,8">
                                    <TextBlock Text="WinPmem can be blocked by driver signature enforcement on hardened systems." Foreground="#D97706" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <Button Content="Acquire Live Memory Dump (WinPmem)" Command="{Binding AcquireWinPmemCommand}" Background="#E91E63" Foreground="White" Padding="12,6" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="1" Header="Magnet RAM Capture - Signed Driver" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="MRC Path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding MagnetRamCapturePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseMagnetRamCaptureCommand}" Margin="0,0,8,0" Padding="10,6"/>
                                    <Button Grid.Column="3" Content="Get Free" Command="{Binding DownloadMagnetRamCaptureCommand}" Background="#2196F3" Foreground="White" Padding="10,6"/>
                                </Grid>
                                <StackPanel Margin="8,0,8,8">
                                    <TextBlock Text="Magnet RAM Capture uses a signed driver and is generally the most compatible option on modern Windows." Foreground="#16A34A" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <Button Content="Launch Magnet RAM Capture" Command="{Binding AcquireMagnetRamCommand}" Background="#9C27B0" Foreground="White" Padding="12,6" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="ProcDump - Process Memory Dump">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="ProcDump Path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding ProcDumpPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseProcDumpCommand}" Margin="0,0,8,0" Padding="10,6"/>
                                <Button Grid.Column="3" Content="Download" Command="{Binding DownloadProcDumpCommand}" Background="#4CAF50" Foreground="White" Padding="10,6"/>

                                <TextBlock Grid.Row="1" Text="Target Process:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding RunningProcessList}" SelectedItem="{Binding SelectedProcessForDump}" Margin="0,8,8,0"/>
                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="Full Dump" IsChecked="{Binding ProcDumpFullDump}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="Create Process Dump" Command="{Binding AcquireProcDumpCommand}" Padding="12,6"/>
                                </StackPanel>
                                <Button Grid.Row="1" Grid.Column="3" Content="Refresh" Command="{Binding RefreshProcessListCommand}" Margin="0,8,0,0" Padding="10,6"/>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Volatility Analysis">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Volatility Path:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding VolatilityPath, UpdateSourceTrigger=PropertyChanged}" Width="350" Margin="0,0,8,0"/>
                        <Button Content="Browse" Command="{Binding BrowseVolatilityCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Download" Command="{Binding DownloadVolatilityCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <TextBlock Text="Memory Dump:" VerticalAlignment="Center" Width="100"/>
                        <TextBox Text="{Binding MemoryDumpPath, UpdateSourceTrigger=PropertyChanged}" Width="350" Margin="0,0,8,0"/>
                        <Button Content="Browse Dump" Command="{Binding BrowseMemoryDumpCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run" Command="{Binding RunVolatilityAnalysisCommand}" Padding="10,6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="Select Volatility Plugins:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox Content="psList" IsChecked="{Binding RunPsList}" Margin="0,0,0,6"/>
                                <CheckBox Content="netScan" IsChecked="{Binding RunNetScan}" Margin="0,0,0,6"/>
                                <CheckBox Content="malfind" IsChecked="{Binding RunMalfind}" Margin="0,0,0,6"/>
                                <CheckBox Content="dllList" IsChecked="{Binding RunDllList}" Margin="0,0,0,6"/>
                                <CheckBox Content="handles" IsChecked="{Binding RunHandles}" Margin="0,0,0,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox Content="cmdline" IsChecked="{Binding RunCmdline}" Margin="0,0,0,6"/>
                                <CheckBox Content="fileScan" IsChecked="{Binding RunFileScan}" Margin="0,0,0,6"/>
                                <CheckBox Content="regHive" IsChecked="{Binding RunRegHive}" Margin="0,0,0,6"/>
                                <CheckBox Content="psTree" IsChecked="{Binding RunPsTree}" Margin="0,0,0,6"/>
                                <CheckBox Content="envars" IsChecked="{Binding RunEnvars}" Margin="0,0,0,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <CheckBox Content="svcScan" IsChecked="{Binding RunSvcScan}" Margin="0,0,0,6"/>
                                <CheckBox Content="callbacks" IsChecked="{Binding RunCallbacks}" Margin="0,0,0,6"/>
                                <CheckBox Content="driverScan" IsChecked="{Binding RunDriverScan}" Margin="0,0,0,6"/>
                                <CheckBox Content="ssdt" IsChecked="{Binding RunSsdt}" Margin="0,0,0,6"/>
                                <CheckBox Content="mutantScan" IsChecked="{Binding RunMutantScan}" Margin="0,0,0,6"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Artifacts">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="KAPE Path:" VerticalAlignment="Center" Width="100"/>
                        <TextBox Text="{Binding KapePath, UpdateSourceTrigger=PropertyChanged}" Width="350" Margin="0,0,8,0"/>
                        <Button Content="Browse" Command="{Binding BrowseKapeCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Get KAPE" Command="{Binding GetKapeCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <TextBlock Text="Target:" VerticalAlignment="Center" Width="60"/>
                        <TextBox Text="{Binding KapeTargetPath, UpdateSourceTrigger=PropertyChanged}" Width="250" Margin="0,0,8,0"/>
                        <Button Content="Browse Target" Command="{Binding BrowseKapeTargetCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run" Command="{Binding RunKapeCollectionCommand}" Padding="10,6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="Select Artifacts to Collect:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox Content="Prefetch" IsChecked="{Binding CollectPrefetch}" Margin="0,0,0,6"/>
                                <CheckBox Content="Amcache" IsChecked="{Binding CollectAmcache}" Margin="0,0,0,6"/>
                                <CheckBox Content="Event Logs" IsChecked="{Binding CollectEventLogs}" Margin="0,0,0,6"/>
                                <CheckBox Content="MFT" IsChecked="{Binding CollectMft}" Margin="0,0,0,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox Content="Registry" IsChecked="{Binding CollectRegistry}" Margin="0,0,0,6"/>
                                <CheckBox Content="SRUM" IsChecked="{Binding CollectSrum}" Margin="0,0,0,6"/>
                                <CheckBox Content="ShellBags" IsChecked="{Binding CollectShellBags}" Margin="0,0,0,6"/>
                                <CheckBox Content="BitLocker" IsChecked="{Binding CollectBitlocker}" Margin="0,0,0,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <CheckBox Content="Recycle Bin" IsChecked="{Binding CollectRecycleBin}" Margin="0,0,0,6"/>
                                <CheckBox Content="Browser Data" IsChecked="{Binding CollectBrowser}" Margin="0,0,0,6"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Timeline">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="Browse Plaso" Command="{Binding BrowsePlasoCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Browse Evidence" Command="{Binding BrowseEvidenceCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run Plaso Timeline" Command="{Binding RunPlasoTimelineCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export Plaso to OpenSearch" Command="{Binding ExportPlasoToOpenSearchCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Download Plaso" Command="{Binding DownloadPlasoCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Browse Velociraptor" Command="{Binding BrowseVelociraptorCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run Velociraptor Collect" Command="{Binding RunVelociraptorCollectCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Download Velociraptor" Command="{Binding DownloadVelociraptorCommand}" Padding="10,6"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Timeline}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="190"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="110"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Processes">
                <DataGrid ItemsSource="{Binding Processes}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="90"/>
                        <DataGridTextColumn Header="Memory MB" Binding="{Binding WorkingSetMb}" Width="100"/>
                        <DataGridTextColumn Header="Responding" Binding="{Binding Responding}" Width="100"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Malware">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="oletools (Office Macro Analysis)" Margin="0,0,0,10">
                            <StackPanel Margin="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="oletools Path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding OletoolsPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseOletoolsCommand}" Padding="10,6"/>

                                    <TextBlock Grid.Row="1" Text="Documents:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DocumentPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,8,0"/>
                                    <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseDocumentsCommand}" Margin="0,8,0,0" Padding="10,6"/>
                                </Grid>

                                <WrapPanel Margin="0,8,0,0">
                                    <CheckBox Content="olevba (VBA extraction)" IsChecked="{Binding RunOlevba}" Margin="0,0,16,0"/>
                                    <CheckBox Content="mraptor (Macro Raptor)" IsChecked="{Binding RunMraptor}"/>
                                </WrapPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="PDF Analysis" Margin="0,0,0,10">
                            <StackPanel Margin="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="pdf-parser.py:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding PdfParserPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="Browse" Command="{Binding BrowsePdfParserCommand}" Padding="10,6"/>
                                </Grid>

                                <CheckBox Content="Analyze PDFs for JavaScript/embedded objects" IsChecked="{Binding RunPdfParser}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="Analyze Documents for Malware" Command="{Binding RunMalwareAnalysisCommand}" Background="#EF4444" Foreground="White" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="Download oletools" Command="{Binding DownloadOletoolsCommand}" Background="#F97316" Foreground="White" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="Download PDF-parser" Command="{Binding DownloadPdfParserCommand}" Background="#F59E0B" Foreground="White" Padding="12,6"/>
                        </WrapPanel>

                        <GroupBox Header="Analysis Results">
                            <DataGrid ItemsSource="{Binding MalwareResults}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="250"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="90"/>
                                    <DataGridCheckBoxColumn Header="Macros" Binding="{Binding HasMacros}" Width="80"/>
                                    <DataGridCheckBoxColumn Header="Suspicious" Binding="{Binding IsSuspicious}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Extract">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Source Path:" VerticalAlignment="Center" Width="100"/>
                        <TextBox Text="{Binding ExtractSourcePath, UpdateSourceTrigger=PropertyChanged}" Width="700" Margin="0,0,8,0"/>
                        <Button Content="Extract" Command="{Binding ExtractArtifactsCommand}" Padding="12,6"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="Browse Bulk Extractor" Command="{Binding BrowseBulkExtractorCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Browse Bulk Input" Command="{Binding BrowseBulkInputCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run Bulk Extractor" Command="{Binding RunBulkExtractorCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Download Bulk Extractor" Command="{Binding DownloadBulkExtractorCommand}" Padding="10,6"/>
                    </WrapPanel>
                    <TextBlock Grid.Row="2" Text="Use this tab to stage artifact extraction workflows from mounted evidence or collection folders."
                               Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

            <TabItem Header="Kusto">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Endpoint:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding KustoEndpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Text="Database:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="3" Text="{Binding KustoDatabase, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBox Grid.Row="1" Text="{Binding KustoQuery, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="160" FontFamily="Consolas"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Load Template" Command="{Binding LoadKustoTemplateCommand}" Padding="12,6" Margin="0,0,8,0"/>
                        <Button Content="Execute Query" Command="{Binding RunKustoQueryCommand}" Padding="12,6"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Local KQL">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="Initialize DB" Command="{Binding InitializeLocalDbCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Refresh Tables" Command="{Binding RefreshTablesCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Clear DB" Command="{Binding ClearLocalDbCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Insert Table Query" Command="{Binding InsertTableQueryCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run Local KQL" Command="{Binding ExecuteLocalKqlCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export Local Results" Command="{Binding ExportLocalResultsCommand}" Padding="10,6"/>
                    </WrapPanel>
                    <TextBox Grid.Row="1" Text="{Binding LocalKqlQuery, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="150" FontFamily="Consolas" Margin="0,0,0,8"/>
                    <Button Grid.Row="2" Content="Run Local KQL (Legacy)" Command="{Binding RunLocalKqlCommand}" Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="3" Text="{Binding LocalKqlOutput}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

            <TabItem Header="OpenSearch">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Endpoint:" VerticalAlignment="Center" Width="90"/>
                        <TextBox Text="{Binding OpenSearchEndpoint, UpdateSourceTrigger=PropertyChanged}" Width="360" Margin="0,0,12,0"/>
                        <TextBlock Text="Index:" VerticalAlignment="Center" Width="60"/>
                        <TextBox Text="{Binding OpenSearchIndex, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="Test Connection" Command="{Binding TestOpenSearchCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Create Pipelines" Command="{Binding CreatePipelinesCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Create Index Templates" Command="{Binding CreateIndexTemplatesCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Ingest" Command="{Binding IngestToOpenSearchCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export to OpenSearch Package" Command="{Binding ExportOpenSearchCommand}" Padding="12,6"/>
                    </WrapPanel>
                    <TextBlock Grid.Row="2" Text="Creates JSONL output package for later bulk indexing into OpenSearch." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="OSINT">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Target:" VerticalAlignment="Center" Width="70"/>
                        <TextBox Text="{Binding OsintTarget, UpdateSourceTrigger=PropertyChanged}" Width="500" Margin="0,0,8,0"/>
                        <Button Content="Browse ExifTool" Command="{Binding BrowseExifToolCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Download ExifTool" Command="{Binding DownloadExifToolCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Extract Metadata" Command="{Binding ExtractMetadataCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Run OSINT" Command="{Binding RunOsintCommand}" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Accepts domain/IP/hash/email targets for investigation workflow tracking." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Schedule">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Workflow Name:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding ScheduleName, UpdateSourceTrigger=PropertyChanged}" Width="420" Margin="0,0,8,0"/>
                        <Button Content="Scan Tasks" Command="{Binding ScanScheduledTasksCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export Tasks" Command="{Binding ExportScheduledTasksCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Save Schedule" Command="{Binding RunScheduleCommand}" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Schedules are recorded as workflow intents for downstream automation." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Browser">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Profile/Data Path:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding BrowserPath, UpdateSourceTrigger=PropertyChanged}" Width="650" Margin="0,0,8,0"/>
                        <Button Content="Browse Profile" Command="{Binding BrowseBrowserProfileCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Scan" Command="{Binding ScanBrowserArtifactsCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export" Command="{Binding ExportBrowserArtifactsCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Collect" Command="{Binding CollectBrowserArtifactsCommand}" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Captures browser artifacts (history, downloads, cache metadata)." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="IOC">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Text="{Binding IocInput, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="Browse IOC File" Command="{Binding BrowseIOCPathCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Load IOC Feed" Command="{Binding LoadIOCFeedCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Scan for IOCs" Command="{Binding ScanForIOCsCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export IOC Results" Command="{Binding ExportIOCResultsCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Parse IOC Set" Command="{Binding CheckIocCommand}" Padding="12,6"/>
                    </WrapPanel>
                    <TextBlock Grid.Row="2" Text="Enter comma, semicolon, or newline separated indicators." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Registry">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Registry Path:" VerticalAlignment="Center" Width="100"/>
                        <TextBox Text="{Binding RegistryPath, UpdateSourceTrigger=PropertyChanged}" Width="700" Margin="0,0,8,0"/>
                        <Button Content="Take Snapshot" Command="{Binding TakeRegistrySnapshotCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Open Snapshots" Command="{Binding OpenRegistrySnapshotFolderCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Collect" Command="{Binding CollectRegistryCommand}" Padding="12,6"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="Browse Snapshot 1" Command="{Binding BrowseSnapshot1Command}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Browse Snapshot 2" Command="{Binding BrowseSnapshot2Command}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Compare Snapshots" Command="{Binding CompareRegistrySnapshotsCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export Diff" Command="{Binding ExportRegistryDiffCommand}" Padding="10,6"/>
                    </WrapPanel>
                    <TextBlock Grid.Row="2" Text="Prepares registry acquisition and triage collection tasks." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="PCAP">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="PCAP File:" VerticalAlignment="Center" Width="80"/>
                        <TextBox Text="{Binding PcapPath, UpdateSourceTrigger=PropertyChanged}" Width="720" Margin="0,0,8,0"/>
                        <Button Content="Browse" Command="{Binding BrowsePcapFileCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Parse" Command="{Binding ParsePcapCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Export" Command="{Binding ExportPcapResultsCommand}" Margin="0,0,8,0" Padding="10,6"/>
                        <Button Content="Analyze" Command="{Binding AnalyzePcapCommand}" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="Runs packet-capture triage and logs analysis task metadata." Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Results">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" ItemsSource="{Binding ForensicsResults}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="190"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="260"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Export" Command="{Binding ExportResultsCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="Clear Log" Command="{Binding ClearLogCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="Clear" Command="{Binding ClearResultsCommand}" Padding="12,6"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
    </Grid>
</UserControl>
