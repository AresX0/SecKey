<UserControl x:Class="SecKey.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10,8" Background="#E8EEF9" BorderBrush="#C8D5EC" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Deployment Status:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding DeploymentStatus}" Margin="10,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#1F2937"/>
            </Grid>
        </Border>

        <Expander DockPanel.Dock="Bottom" Margin="0,12,0,0" Header="Deployment History" IsExpanded="False">
            <DataGrid ItemsSource="{Binding DeploymentHistory}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MinHeight="120" MaxHeight="220">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="90"/>
                    <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="180"/>
                    <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="110"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Tenant overview" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,6" Margin="16,0,0,0"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#6B7280"/>
        </StackPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Content="Deploy Full Environment" Command="{Binding ApplyFullEnvironmentCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Intune Apps" Command="{Binding DeployIntuneAppsCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Groups" Command="{Binding DeployGroupsCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Conditional Access" Command="{Binding DeployConditionalAccessCommand}" Padding="14,6" Margin="0,0,8,8"/>
        </WrapPanel>

        <Expander DockPanel.Dock="Top" Margin="0,0,0,12" Header="Native Deployment Settings" IsExpanded="True">
            <DataGrid ItemsSource="{Binding SettingsInventory}" AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="180" MaxHeight="260">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Setting" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Value" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160" IsReadOnly="True" ElementStyle="{StaticResource SettingSourceBadgeTextStyle}"/>
                    <DataGridTemplateColumn Header="Actions" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save" Command="{Binding DataContext.SaveSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4" Margin="0,0,8,0"/>
                                    <Button Content="Go to editor" Command="{Binding DataContext.NavigateToSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <Expander DockPanel.Dock="Top" Margin="0,0,0,12" Header="Live JSON Policy Settings (Individual Editor)" IsExpanded="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <WrapPanel Margin="0,0,0,8">
                    <TextBlock Text="Filter" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="320" Text="{Binding PolicySettingsFilter, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                    <Button Content="Reload" Command="{Binding ReloadPolicySettingsCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Content="Set Current As Default Baseline" Command="{Binding SetCurrentAsDefaultBaselineCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Content="Reset All Managed JSON To Baseline" Command="{Binding ResetAllManagedJsonToDefaultBaselineCommand}" Padding="12,4"/>
                </WrapPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PolicySettings}" AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="220" MaxHeight="380" EnableRowVirtualization="True" EnableColumnVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="File" Binding="{Binding RelativeFilePath}" Width="280" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Setting" Binding="{Binding DisplayName}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="JSON Path" Binding="{Binding JsonPath}" Width="260" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding ValueType}" Width="90" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Value" Width="260">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="320">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Save" Command="{Binding DataContext.SavePolicySettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4" Margin="0,0,6,0"/>
                                        <Button Content="Open JSON" Command="{Binding DataContext.OpenPolicyJsonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4" Margin="0,0,6,0"/>
                                        <Button Content="Open Azure" Command="{Binding DataContext.OpenAzureSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Expander>

        <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="220" Height="100" Margin="8" Background="#F3F4F6" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Description}" Foreground="#6B7280" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
