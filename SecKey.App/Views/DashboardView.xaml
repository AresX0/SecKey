<UserControl x:Class="SecKey.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10,8" Background="#E8EEF9" BorderBrush="#C8D5EC" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Deployment Status:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding DeploymentStatus}" Margin="10,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#1F2937"/>
            </Grid>
        </Border>

        <Expander DockPanel.Dock="Bottom" Margin="0,12,0,0" Header="Deployment History" IsExpanded="False">
            <DataGrid ItemsSource="{Binding DeploymentHistory}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MinHeight="120" MaxHeight="220">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="90"/>
                    <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="180"/>
                    <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="110"/>
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Tenant overview" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,6" Margin="16,0,0,0"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#6B7280"/>
        </StackPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button Content="Deploy Full Environment" Command="{Binding ApplyFullEnvironmentCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Intune Apps" Command="{Binding DeployIntuneAppsCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Groups" Command="{Binding DeployGroupsCommand}" Padding="14,6" Margin="0,0,8,8"/>
            <Button Content="Deploy Conditional Access" Command="{Binding DeployConditionalAccessCommand}" Padding="14,6" Margin="0,0,8,8"/>
        </WrapPanel>
        <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="220" Height="100" Margin="8" Background="#F3F4F6" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Description}" Foreground="#6B7280" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
