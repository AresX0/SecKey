<UserControl x:Class="SecKey.App.Views.IntuneBackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Intune Configuration Backup" FontSize="22" FontWeight="Bold" Foreground="White" Background="{DynamicResource SectionHeaderBrush}" Padding="16"/>

        <Grid Grid.Row="1" Margin="14,10,14,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Project Root" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding ProjectRootPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="Tenant ID" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="3" Text="{Binding TenantId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                <Button Grid.Column="4" Content="Refresh" Command="{Binding RefreshBackupListCommand}" Padding="10,6"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding BackupName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Create Backup" Command="{Binding CreateBackupCommand}" Margin="0,0,8,0" Padding="10,6"/>
                <Button Grid.Column="2" Content="Restore Selected" Command="{Binding RestoreSelectedBackupCommand}" Margin="0,0,8,0" Padding="10,6"/>
                <Button Grid.Column="3" Content="Delete Selected" Command="{Binding DeleteBackupCommand}" CommandParameter="{Binding SelectedBackup}" Margin="0,0,8,0" Padding="10,6"/>
                <Button Grid.Column="4" Content="Open Backup Root" Command="{Binding OpenBackupRootCommand}" Margin="0,0,8,0" Padding="10,6"/>
                <Button Grid.Column="5" Content="Open Selected Backup" Command="{Binding OpenSelectedBackupFolderCommand}" Padding="10,6"/>
                <Button Grid.Column="6" Content="Export Inventory" Command="{Binding ExportBackupInventoryCommand}" Margin="8,0,0,0" Padding="10,6"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="14,0,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="Restore Intune Apps" IsChecked="{Binding RestoreIntuneApps}" Margin="0,0,14,0" VerticalAlignment="Center"/>
            <CheckBox Grid.Column="1" Content="Restore JSON" IsChecked="{Binding RestoreJson}" Margin="0,0,14,0" VerticalAlignment="Center"/>
            <CheckBox Grid.Column="2" Content="Restore Remediation" IsChecked="{Binding RestoreRemediationScripts}" Margin="0,0,14,0" VerticalAlignment="Center"/>
            <CheckBox Grid.Column="3" Content="Restore Settings Snapshot" IsChecked="{Binding RestoreSettingsSnapshot}" Margin="0,0,14,0" VerticalAlignment="Center"/>
            <CheckBox Grid.Column="4" Content="Overwrite Existing" IsChecked="{Binding OverwriteExisting}" Margin="0,0,14,0" VerticalAlignment="Center"/>
            <Button Grid.Column="5" Content="Open Selected Backup" Command="{Binding OpenSelectedBackupFolderCommand}" Padding="10,6"/>
        </Grid>

        <ScrollViewer Grid.Row="3" Margin="14,0,14,8" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True" PanningMode="VerticalFirst">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding AvailableBackups}"
                          SelectedItem="{Binding SelectedBackup}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MinHeight="180"
                          HorizontalAlignment="Stretch"
                          MaxHeight="320"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Backup Name" Binding="{Binding BackupName}" Width="2*"/>
                        <DataGridTextColumn Header="Tenant" Binding="{Binding TenantId}" Width="*"/>
                        <DataGridTextColumn Header="Created" Binding="{Binding CreatedAtFormatted}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="*"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding BackupPath}" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Margin="0,8,0,0" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8">
                    <TextBlock Text="{Binding SelectedBackupDetails}" TextWrapping="Wrap" FontFamily="Consolas"/>
                </Border>

                <Border Grid.Row="2" Margin="0,8,0,0" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Backup Compare" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Compare Against:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AvailableBackups}" SelectedItem="{Binding CompareBackup}" DisplayMemberPath="BackupName" Width="280" Margin="0,0,8,0"/>
                            <Button Content="Compare" Command="{Binding CompareSelectedBackupsCommand}" Padding="10,6"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CompareSummary}" TextWrapping="Wrap" FontFamily="Consolas" Margin="0,0,0,12"/>

                        <TextBlock Text="Baseline Compare" FontWeight="Bold" FontSize="14" Margin="0,12,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding CompareFolderA, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseCompareFolderACommand}" Margin="0,0,8,0" Padding="10,6"/>
                            <TextBox Grid.Column="2" Text="{Binding BaselineFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Button Content="Browse Baseline" Command="{Binding BrowseBaselineFolderCommand}" Margin="0,0,8,0" Padding="10,6"/>
                                <Button Content="Run Baseline Compare" Command="{Binding RunBaselineCompareCommand}" Padding="10,6"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Cross-Tenant Compare" FontWeight="Bold" FontSize="14" Margin="0,12,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SourceExportFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseSourceExportFolderCommand}" Margin="0,0,8,0" Padding="10,6"/>
                            <TextBox Grid.Column="2" Text="{Binding TargetExportFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Button Content="Browse Target" Command="{Binding BrowseTargetExportFolderCommand}" Margin="0,0,8,0" Padding="10,6"/>
                                <Button Content="Compare Tenants" Command="{Binding RunCrossTenantCompareCommand}" Padding="10,6"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Compare Folder A/B" Command="{Binding RunCompareFoldersCommand}" Padding="10,6" Margin="0,8,0,0" HorizontalAlignment="Left"/>

                        <TextBlock Text="Cross-Tenant Import Plan" FontWeight="Bold" FontSize="14" Margin="0,12,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Generate Import Plan (uses above Source/Target folders)" Command="{Binding GenerateCrossTenantImportPlanCommand}" Margin="0,0,8,0" Padding="10,6" HorizontalAlignment="Left" Width="350"/>
                            <TextBlock Grid.Column="1" Text="{Binding CompareReportPath}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <TextBlock Text="Compare Results:" FontWeight="Bold" FontSize="12" Margin="0,12,0,4"/>
                        <TextBlock Text="{Binding CompareSummary}" TextWrapping="Wrap" FontFamily="Consolas" Background="{DynamicResource CardBrush}" Padding="4"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="4" Margin="14,0,14,12" Background="{DynamicResource StatusPanelBrush}" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Padding="8">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
