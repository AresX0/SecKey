<UserControl x:Class="SecKey.App.Views.PoliciesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Apply Step-by-Step (policy deployment):" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding DeploymentCommands}" SelectedItem="{Binding SelectedDeploymentCommand, Mode=TwoWay}" Width="380" Margin="8,0,0,0"/>
                <Button Content="Apply Selected Step" Command="{Binding ApplySelectedDeploymentStepCommand}" Padding="14,6" Margin="8,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Compliance / Configuration / Settings Catalog" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,6" Margin="16,0,0,0"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#6B7280"/>
            </StackPanel>
        </StackPanel>
        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Type" Binding="{Binding Description}" Width="160"/>
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="240"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
