<UserControl x:Class="SecKey.App.Views.YaraScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="YARA Scanner (Native YARA-Lite)" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Target" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Grid.Column="1" Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Scan" Command="{Binding ScanCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>

        <GroupBox Grid.Row="2" Header="Rules" Margin="0,0,0,8">
            <TextBox Text="{Binding RulesInput, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="90" FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Matches}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Rule" Binding="{Binding RuleName}" Width="220"/>
                <DataGridTextColumn Header="Matches" Binding="{Binding MatchCount}" Width="100"/>
                <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}"/>
    </Grid>
</UserControl>
