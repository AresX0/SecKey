<UserControl x:Class="SecKey.App.Views.UploadAppView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Upload Win32 LOB App" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <DockPanel Grid.Row="1" Margin="0,4">
            <TextBlock Text="App folder:" Width="120" VerticalAlignment="Center"/>
            <Button Content="Browse..." Command="{Binding BrowseFolderCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <TextBox Text="{Binding AppFolder, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
        </DockPanel>

        <DockPanel Grid.Row="2" Margin="0,4">
            <TextBlock Text="IntuneWinAppUtil.exe:" Width="120" VerticalAlignment="Center"/>
            <Button Content="Browse..." Command="{Binding BrowseToolCommand}" Padding="10,4" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <TextBox Text="{Binding IntuneWinAppUtilPath, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
        </DockPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12">
            <Button Content="Run" Command="{Binding RunCommand}" Padding="20,8" FontWeight="Bold"/>
            <TextBlock Text="{Binding Stage}" Margin="16,0" VerticalAlignment="Center"/>
            <ProgressBar Value="{Binding Progress}" Maximum="100" Width="280" Height="14" Margin="8,0"/>
        </StackPanel>

        <ListBox Grid.Row="4" ItemsSource="{Binding LogLines}" FontFamily="Consolas" FontSize="12" BorderBrush="#D1D5DB"/>
    </Grid>
</UserControl>
