<UserControl x:Class="SecKey.App.Views.SystemAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="10" Background="{DynamicResource WindowBackgroundBrush}" LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#F59E0B" Padding="10" Margin="0,0,0,8"
                Visibility="{Binding NeedsElevation, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Administrative privileges required for full system audit. Some checks may be limited unless SecKey runs as administrator."
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       TextWrapping="Wrap"/>
        </Border>

        <Border DockPanel.Dock="Top" Background="{DynamicResource SectionHeaderBrush}" Padding="14" Margin="0,0,0,8">
            <TextBlock Text="System Audit" FontSize="22" FontWeight="Bold" Foreground="White"/>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <GroupBox Header="Audit Actions" Margin="0,0,0,8">
                <WrapPanel Margin="8">
                    <Button Content="Full Audit" Command="{Binding RunFullAuditCommand}" Margin="0,0,8,8"/>
                    <Button Content="Firewall" Command="{Binding RunFirewallAuditCommand}" Margin="0,0,8,8"/>
                    <Button Content="Updates" Command="{Binding RunUpdatesAuditCommand}" Margin="0,0,8,8"/>
                    <Button Content="Startup" Command="{Binding RunStartupAuditCommand}" Margin="0,0,8,8"/>
                    <Button Content="Elevated Users" Command="{Binding ScanElevatedUsersCommand}" Margin="0,0,8,8"/>
                    <Button Content="Critical ACLs" Command="{Binding ScanCriticalAclsCommand}" Margin="0,0,8,8"/>
                    <Button Content="Outbound" Command="{Binding ScanOutboundTrafficCommand}" Margin="0,0,8,8"/>
                    <Button Content="Inbound" Command="{Binding ScanInboundTrafficCommand}" Margin="0,0,8,8"/>
                    <Button Content="Users &amp; Groups" Command="{Binding OpenUsersAndGroupsCommand}" Margin="0,0,8,8"/>
                    <Button Content="Fix All" Command="{Binding FixAllCommand}" Margin="0,0,8,8"/>
                    <Button Content="Export Report" Command="{Binding ExportReportCommand}" Margin="0,0,8,8"/>
                    <Button Content="Clear" Command="{Binding ClearCommand}" Margin="0,0,8,8"/>
                </WrapPanel>
            </GroupBox>

            <GroupBox Header="Filters and User Actions" Margin="0,0,0,8">
                <StackPanel Margin="8">
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Category:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="180" Margin="0,0,20,0"/>
                        <TextBlock Text="Severity:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Severities}" SelectedItem="{Binding SelectedSeverity}" Width="140" Margin="0,0,20,0"/>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Username:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding SelectedUsername, UpdateSourceTrigger=PropertyChanged}" Width="170" Margin="0,0,8,0"/>
                        <TextBlock Text="Password:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Width="170" Margin="0,0,8,0"/>
                        <Button Content="Disable" Command="{Binding DisableUserCommand}" Margin="0,0,8,0"/>
                        <Button Content="Delete" Command="{Binding DeleteUserCommand}" Margin="0,0,8,0"/>
                        <Button Content="Reset PW" Command="{Binding ResetPasswordCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Summary" Margin="0,0,0,8">
                <WrapPanel Margin="8">
                    <Border BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,8,0">
                        <TextBlock Text="{Binding TotalIssues, StringFormat=Total: {0}}" FontWeight="SemiBold"/>
                    </Border>
                    <Border BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,8,0">
                        <TextBlock Text="{Binding CriticalIssues, StringFormat=Critical: {0}}" Foreground="#B91C1C" FontWeight="SemiBold"/>
                    </Border>
                    <Border BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8">
                        <TextBlock Text="{Binding WarningIssues, StringFormat=Warnings: {0}}" Foreground="#C2410C" FontWeight="SemiBold"/>
                    </Border>
                </WrapPanel>
            </GroupBox>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Background="{DynamicResource StatusPanelBrush}" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Padding="8">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Height="10" Minimum="0" Maximum="100" Value="{Binding AuditProgressPercent}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressMessage}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid ItemsSource="{Binding AuditItems}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*"/>
                <DataGridTemplateColumn Header="Fix" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Fix" Command="{Binding DataContext.FixIssueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" IsEnabled="{Binding CanAutoFix}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
