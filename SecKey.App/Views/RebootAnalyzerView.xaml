<UserControl x:Class="SecKey.App.Views.RebootAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Reboot &amp; Crash Analysis" FontSize="22" FontWeight="Bold" Foreground="White" Background="{DynamicResource SectionHeaderBrush}" Padding="16"/>

        <WrapPanel Grid.Row="1" Margin="14,10,14,8" VerticalAlignment="Center">
            <TextBlock Text="Days to Analyze:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Width="80" Text="{Binding DaysToAnalyze, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Content="Analyze" Command="{Binding AnalyzeRebootsCommand}" Margin="0,0,8,0" Padding="10,6"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="10,6"/>
        </WrapPanel>

        <Grid Grid.Row="2" Margin="14,0,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,6,0">
                <TextBlock Text="{Binding SystemUptime, StringFormat=Uptime: {0}}"/>
            </Border>
            <Border Grid.Column="1" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,6,0">
                <TextBlock Text="{Binding LastBootTime, StringFormat=Last Boot: {0:g}}"/>
            </Border>
            <Border Grid.Column="2" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8" Margin="0,0,6,0">
                <TextBlock Text="{Binding UnexpectedReboots.Count, StringFormat=Unexpected: {0}}"/>
            </Border>
            <Border Grid.Column="3" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBrush}" Padding="8">
                <TextBlock Text="{Binding BsodEvents.Count, StringFormat=BSOD: {0}}"/>
            </Border>
        </Grid>

        <TabControl Grid.Row="3" Margin="14,0,14,8">
            <TabItem Header="Unexpected Reboots">
                <DataGrid ItemsSource="{Binding UnexpectedReboots}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="BSOD Events">
                <DataGrid ItemsSource="{Binding BsodEvents}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Application Crashes">
                <DataGrid ItemsSource="{Binding ApplicationCrashes}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Crash Dumps">
                <DataGrid ItemsSource="{Binding CrashDumps}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Clean Shutdowns">
                <DataGrid ItemsSource="{Binding CleanShutdowns}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Root Cause Summary">
                <DataGrid ItemsSource="{Binding RootCauseSummary}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Root Cause" Binding="{Binding Key}" Width="*"/>
                        <DataGridTextColumn Header="Count" Binding="{Binding Value}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="4" Margin="14,0,14,12" Background="{DynamicResource StatusPanelBrush}" BorderBrush="{DynamicResource StatusPanelBorderBrush}" BorderThickness="1" Padding="8">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
