<UserControl x:Class="SecKey.App.Views.DeviceTaggingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Windows Device Extension Attributes" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Pick a Windows device from the list or enter a device name, then set extensionAttribute1=SECKEY (or any extensionAttribute value)."
                       Margin="0,8,0,0"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Refresh Devices" Command="{Binding RefreshCommand}" Padding="14,6"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#6B7280"/>
            </StackPanel>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         ToolTip="Optional device display name (used if provided)."/>
                <TextBox Grid.Column="1"
                         Text="{Binding ExtensionAttributeNumber, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         ToolTip="Extension attribute number between 1 and 15."/>
                <TextBox Grid.Column="2"
                         Text="{Binding AttributeValue, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         ToolTip="Value to set for the extension attribute."/>
                <Button Grid.Column="3" Content="Set Attribute" Command="{Binding SetAttributeCommand}" Padding="14,6"/>
            </Grid>

            <TextBlock Text="Fields: Device Name | Attribute Number | Value"
                       Margin="0,6,0,0"
                       Foreground="#6B7280"/>
        </StackPanel>

        <Expander DockPanel.Dock="Top" Margin="0,0,0,12" Header="Native Deployment Settings" IsExpanded="False">
            <DataGrid ItemsSource="{Binding SettingsInventory}" AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="140" MaxHeight="220">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Setting" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Value" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160" IsReadOnly="True" ElementStyle="{StaticResource SettingSourceBadgeTextStyle}"/>
                    <DataGridTemplateColumn Header="Actions" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save" Command="{Binding DataContext.SaveSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4" Margin="0,0,8,0"/>
                                    <Button Content="Go to editor" Command="{Binding DataContext.NavigateToSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Padding="10,4"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <DataGrid ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                <DataGridTextColumn Header="Operating System" Binding="{Binding Description}" Width="180"/>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
